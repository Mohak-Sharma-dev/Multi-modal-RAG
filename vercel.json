{
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "runtime": "nodejs22.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "regions": ["iad1"],
  "env": {
    "GEMINI_API_KEY": "",
    "UPSTASH_REDIS_REST_URL": "",
    "UPSTASH_REDIS_REST_TOKEN": "",
    "INDEX_NAME": "rag_vectors"
  }
}