{
  "name": "multi-modal-rag",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "docker:build": "docker build -t multi-modal-rag .",
    "docker:run": "docker run -p 3000:3000 --env-file .env multi-modal-rag",
    "docker:compose": "docker-compose up -d",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured'"
  },
  "dependencies": {
    "@google/generative-ai": "^0.15.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "formidable": "^3.5.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/formidable": "^3.4.5",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
